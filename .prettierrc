{
  "trailingComma": "none",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "overrides": [
    {
      "files": ["*.json", "*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    },
    {
      "files": ["*.toml"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}
