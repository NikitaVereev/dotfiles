{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "margin-right": 12,
  "margin-left": 12,
  "margin-top": 4,
  "modules-left": ["custom/hypr", "custom/window"],
  "modules-center": ["group/center3", "hyprland/workspaces", "group/center2"],
  "modules-right": ["group/right1"],

  "group/center2": {
    "orientation": "inherit",
    "modules": ["clock", "custom/update"]
  },

  "group/center3": {
    "orientation": "inherit",
    "modules": ["cpu", "memory", "custom/separator#blank", "mpris"]
  },

  "group/right1": {
    "orientation": "inherit",
    "modules": [
      "hyprland/language",
      "pulseaudio",
      "bluetooth",
      "network",
      "battery"
    ]
  },

  "hyprland/language": {
    "format": "{short}",
    "tooltip-format": "Keyboard: {layout}",
    "on-click": "hyprctl switchxkblayout all next"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "",
      "active": "",
      "empty": ""
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": [],
      "7": [],
      "8": []
    }
  },

  "custom/window": {
    "exec": "~/.config/waybar/scripts/window.sh",
    "return-type": "json",
    "format": "{}",
    "signal": 8
  },

  "custom/hypr": {
    "format": "<span size='11500'></span>",
    "on-click": "rofi -show drun",
    "tooltip-format": "Rofi Menu\n\nAlt + R"
  },

  "cpu": {
    "interval": 5,
    "format": "{icon} ",
    "format-icons": ["󰪞", "󰪟", "󰪠", "󰪡", "󰪢", "󰪣", "󰪤", "󰪥"],
    "on-click": "kitty htop"
  },

  "memory": {
    "interval": 5,
    "format": "{icon} ",
    "format-icons": ["󰪞", "󰪟", "󰪠", "󰪡", "󰪢", "󰪣", "󰪤", "󰪥"],
    "on-click": "kitty htop"
  },

  "clock": {
    "format": "{:%H:%M · %a, %d/%m}",
    "format-alt": "{:%A, %d %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "network": {
    "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "󰌘",
    "format-disconnected": "󰤭",
    "tooltip-format-wifi": "{essid}\\n{signalStrength}% · {frequency}GHz",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 15,
    "on-click": "kitty nmtui"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": {
      "charging": ["󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"],
      "default": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },
    "format-full": "󰂅",
    "tooltip-format-discharging": "{power:>1.0f}W↓ {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}W↑ {capacity}%",
    "interval": 10,
    "states": {
      "good": 95,
      "warning": 40,
      "critical": 20
    }
  },

  "bluetooth": {
    "format": "<span size='11500'>󰂯</span>",
    "format-disabled": "<span size='11500'>󰂲</span>",
    "format-connected": "<span size='11500'></span>",
    "format-no-controller": "",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "blueman-manager"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "on-click": "pavucontrol",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "󰝟",
    "format-icons": {
      "default": ["󰕾", "󰖀", "󰕾"]
    }
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },
  "mpris": {
    "format": "<span size='11500'>{player_icon}</span> {artist} - {title}",
    "interval": 2,
    "max-length": 35,
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "ignored-players": ["Chromium", "Firefox"],
    "player-icons": {
      "chromium": "",
      "default": "",
      "firefox": "",
      "mopidy": "",
      "spotify": ""
    }
  },

  "custom/separator#blank": {
    "format": " ",
    "interval": "once",
    "tooltip": false
  },

  "custom/separator#dot": {
    "format": " ",
    "interval": "once",
    "tooltip": false
  },

  "custom/update": {
    "format": "   {}",
    "exec": "~/.config/waybar/scripts/updates.sh",
    "interval": 1800,
    "signal": 8,
    "on-click": "kitty sh -c 'sudo pacman -Syu; pkill -RTMIN+8 waybar; echo; echo \"Press Enter to exit\"; read'",
    "tooltip-format": "{} updates available"
  }
}
