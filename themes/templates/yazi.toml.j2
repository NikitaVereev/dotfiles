# ═══════════════════════════════════════════════════════════════════════════════
# {{ meta.name }} Theme for Yazi
# Generated by theme-manager.py
# ═══════════════════════════════════════════════════════════════════════════════

[manager]
cwd = { fg = "{{ accent_blue }}" }

hovered         = { fg = "{{ base_bg0 }}", bg = "{{ accent_green }}" }
preview_hovered = { underline = true }

find_keyword  = { fg = "{{ accent_yellow }}", bold = true, italic = true, underline = true }
find_position = { fg = "{{ accent_purple }}", bg = "reset", bold = true, italic = true }

marker_copied   = { fg = "{{ accent_aqua }}", bg = "{{ accent_aqua }}" }
marker_cut      = { fg = "{{ accent_red }}", bg = "{{ accent_red }}" }
marker_marked   = { fg = "{{ accent_purple }}", bg = "{{ accent_purple }}" }
marker_selected = { fg = "{{ accent_yellow }}", bg = "{{ accent_yellow }}" }

tab_width          = 1
tab_use_inverse    = false
selected           = { fg = "{{ base_fg1 }}", reversed = true }
count_copied       = { fg = "{{ base_fg1 }}", bg = "{{ accent_blue }}" }
count_cut          = { fg = "{{ base_fg1 }}", bg = "{{ accent_red }}" }
count_selected     = { fg = "{{ base_fg1 }}", bg = "{{ accent_yellow }}" }

border_symbol = "│"
border_style  = { fg = "{{ ui_border }}" }

[status]
separator_open  = ""
separator_close = ""
separator_style = { fg = "{{ base_bg3 }}", bg = "{{ base_bg3 }}" }

mode_normal = { fg = "{{ base_bg0 }}", bg = "{{ accent_blue }}",    bold = true }
mode_select = { fg = "{{ base_bg0 }}", bg = "{{ accent_yellow }}",  bold = true }
mode_unset  = { fg = "{{ base_bg0 }}", bg = "{{ accent_purple }}", bold = true }

progress_label  = { bold = true }
progress_normal = { fg = "{{ accent_blue }}", bg = "{{ base_bg2 }}" }
progress_error  = { fg = "{{ accent_red }}", bg = "{{ base_bg2 }}" }

permissions_t = { fg = "{{ accent_aqua }}" }
permissions_r = { fg = "{{ accent_yellow }}" }
permissions_w = { fg = "{{ accent_red }}" }
permissions_x = { fg = "{{ accent_green }}" }
permissions_s = { fg = "{{ base_bg3 }}" }

[input]
border   = { fg = "{{ accent_blue }}" }
title    = {}
value    = {}
selected = { reversed = true }

[select]
border   = { fg = "{{ accent_blue }}" }
active   = { fg = "{{ accent_purple }}" }
inactive = {}

[tasks]
border  = { fg = "{{ accent_blue }}" }
title   = {}
hovered = { underline = true }

[which]
mask            = { bg = "{{ base_bg2 }}" }
cand            = { fg = "{{ accent_aqua }}" }
rest            = { fg = "{{ base_bg3 }}" }
desc            = { fg = "{{ accent_purple }}" }
separator       = "  "
separator_style = { fg = "{{ base_bg3 }}" }

[help]
on      = { fg = "{{ accent_purple }}" }
exec    = { fg = "{{ accent_aqua }}" }
desc    = { fg = "{{ base_bg3 }}" }
hovered = { bg = "{{ base_bg2 }}", bold = true }
footer  = { fg = "{{ base_bg0 }}", bg = "{{ base_fg1 }}" }

[filetype]
rules = [
  { mime = "image/*",     fg = "{{ accent_aqua }}" },
  { mime = "video/*",     fg = "{{ accent_purple }}" },
  { mime = "audio/*",     fg = "{{ accent_purple }}" },
  { mime = "application/zip",   fg = "{{ accent_yellow }}" },
  { mime = "application/gzip",  fg = "{{ accent_yellow }}" },
  { mime = "application/x-tar", fg = "{{ accent_yellow }}" },
  { mime = "application/zstd",  fg = "{{ accent_yellow }}" },
  { name = "*",  is = "exec", fg = "{{ accent_green }}" },
  { name = ".*", fg = "{{ base_bg3 }}" },
  { name = "*", is = "link",    fg = "{{ accent_aqua }}" },
  { name = "*", is = "orphan",  fg = "{{ accent_red }}" },
]
