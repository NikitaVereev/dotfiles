# ═══════════════════════════════════════════════════════════════
# Dotfiles .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Test & Debug ───────────────────────────────────────────────
tt.*
.tests
foo.*
debug
.repro
data

# ── Logs ───────────────────────────────────────────────────────
*.log

# ── Editor ─────────────────────────────────────────────────────
# Vim tags
doc/tags

# Backup files
*.swp
*.swo
*~

# ── System ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Plugins (auto-install via Lazy.nvim / TPM) ─────────────────
.config/nvim/plugin/
.config/tmux/plugins/

# ── Tmux ───────────────────────────────────────────────────────
# Tmux resurrect backups
.config/tmux/resurrect/

# ── Local Configuration (machine-specific) ─────────────────────
# Hyprland monitor configuration (per-machine)
.config/hypr/modules/monitors.conf

# Current theme symlinks (auto-generated)
.config/hypr/themes/current.conf
.config/kitty/themes/current.conf
.config/nvim/themes/current
.config/rofi/current.rasi
.config/waybar/themes/current.css
.config/swaync/themes/current.css
.config/starship/themes/current.toml

# ── Cache ──────────────────────────────────────────────────────
.cache/

# ── Lazy.nvim lock file (optional - commit if you want pinned versions) ─
# .config/nvim/lazy-lock.json
