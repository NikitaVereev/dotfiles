# ═══════════════════════════════════════════════════════════════
# Dotfiles .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Test & Debug ───────────────────────────────────────────────
tt.*
.tests
foo.*
debug
.repro
data

# ── Logs ───────────────────────────────────────────────────────
*.log

# ── Editor ─────────────────────────────────────────────────────
# Vim tags
doc/tags

# Backup files
*.swp
*.swo
*~

# ── System ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Plugins (auto-install via Lazy.nvim / TPM) ─────────────────
.config/nvim/plugin/
.config/tmux/plugins/

# ── Tmux ───────────────────────────────────────────────────────
# Tmux resurrect backups
.config/tmux/resurrect/

# ── Local Configuration (machine-specific) ─────────────────────
# Hyprland monitor configuration (per-machine)
.config/hypr/modules/monitors.conf

# Generated theme files (auto-generated by theme-manager.py)
.config/hypr/themes/*.conf
.config/kitty/themes/*.conf
.config/rofi/current.rasi
.config/rofi/themes/*.rasi
.config/starship/themes/*.toml
.config/swaync/themes/*.css
.config/tmux/themes/*.conf
.config/waybar/themes/*.css
.config/yazi/themes/*.toml
.config/nvim/themes/current_theme

# Theme palette symlink
themes/palettes/current.toml

# ── Cache ──────────────────────────────────────────────────────
.cache/


# ── Lazy.nvim lock file (optional - commit if you want pinned versions) ─
# .config/nvim/lazy-lock.json

# Wallpapers (user content)
wallpapers/original/
wallpapers/cache/

# Generated wallpapers (auto-generated)
wallpapers/generated/
__pycache__/
